# ─── NutriVet.IA — Variables de Entorno ──────────────────────────────────────
# Copiar a .env y completar con valores reales.
# NUNCA commitear .env con datos de producción.
# En Coolify/Docker: configurar estas variables en el dashboard.

# ─── Base de Datos ─────────────��─────────────────────────────────────────────
DB_NAME=nutrivet
DB_USER=nutrivet
DB_PASSWORD=                          # Generar: openssl rand -base64 32
DATABASE_URL=postgresql+psycopg2://nutrivet:PASS@localhost:5432/nutrivet
DATABASE_URL_ASYNC=postgresql+asyncpg://nutrivet:PASS@localhost:5432/nutrivet

# ─── Redis (ARQ worker + rate limiter) ───────────���───────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ��────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=                       # Generar: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256

# ─── Encriptación AES-256 (campos médicos en reposo — REGLA 6) ──────────────
FERNET_KEY=                           # Generar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ─── OpenRouter (LLM provider unificado) ─────────��──────────────────────────
OPENROUTER_API_KEY=                   # Obtener en: https://openrouter.ai/keys
OPENROUTER_REFERER=https://nutrivet-ia.com

# ─── CORS (orígenes permitidos separados por coma — NUNCA wildcard) ──────────
# Producción: https://app.nutrivet.ia,https://vet.nutrivet.ia
# Dev local:  http://localhost:3000,http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Cloudflare R2 (storage S3-compatible) ───────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nutrivet-prod

# ─── PayU Colombia (pagos) ──────��────────────────────────────────────────────
PAYU_MERCHANT_ID=
PAYU_API_KEY=
PAYU_API_LOGIN=
PAYU_ACCOUNT_ID=
PAYU_ENV=sandbox                      # sandbox | production

# ─── App ──────────────────────────────────────────────────────────────��──────
APP_BASE_URL=https://nutrivet.app     # URL pública de la app (webhooks, deep links)
APP_PORT=8000

# ─── Firebase Cloud Messaging (push notifications) ──────────────────────────
# JSON completo del Service Account como string de una línea.
# Obtener en: Firebase Console → Project Settings → Service Accounts → Generate Key
FCM_SERVICE_ACCOUNT_JSON=

# ─── Observabilidad ────���─────────────────────────────────────────────────────
LOG_FORMAT=json                       # json (producción) | console (desarrollo)
SENTRY_DSN=                           # Obtener en: sentry.io → Project → Settings → DSN

# ─── Feature Flags ──────��────────────────────────────────────────────────────
MVP_FREEMIUM_DISABLED=true            # true = sin restricciones de tier (piloto)
